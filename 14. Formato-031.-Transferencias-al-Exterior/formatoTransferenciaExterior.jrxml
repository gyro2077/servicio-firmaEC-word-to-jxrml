				<textElement textAlignment="Justified">
					<font fontName="Arial" size="7"/>
				</textElement>
				<textFieldExpression><![CDATA["* Cuando se trate de transferencias en USD a favor de beneficiarios fuera de los Estados Unidos y en EUR a favor de beneficiarios fuera de la Unión Europea"]]></textFieldExpression>
			</textField>
			<textField isStretchWithOverflow="true">
