			<expression><![CDATA["* Cuando se trate de transferencias en USD a favor de beneficiarios fuera de los Estados Unidos y en EUR a favor de beneficiarios fuera de la Unión Europea"]]></expression>
		</element>
		<element kind="textField" uuid="d8db7e0b-779c-49a7-95df-dba3b2a1e12b" x="0" y="326" width="450" height="10" fontName="Arial" fontSize="7.0" textAdjust="StretchHeight" hTextAlign="Justified">
