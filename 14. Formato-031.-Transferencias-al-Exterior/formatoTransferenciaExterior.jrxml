		</element>
		<element kind="textField" uuid="9287f2c6-c2d0-46c3-b475-f2242c8bcf4a" x="0" y="338" width="450" height="10" fontName="Arial" fontSize="7.0" textAdjust="StretchHeight" bold="true" hTextAlign="Justified">
			<expression><![CDATA["Nota 1: La información que se consigna en este documento deberá estar libre de enmendaduras"]]></expression>
		</element>
		<element kind="textField" uuid="5436ea18-2a9c-48a7-bf26-3e382bd36d33" x="0" y="350" width="450" height="28" fontName="Arial" fontSize="7.0" textAdjust="StretchHeight" hTextAlign="Justified">
			<expression><![CDATA["Nota 2: En el caso que la transferencia se realice a un país con el cual se mantiene convenio de doble tributación se deberá analizar el porcentaje de retención en la fuente del impuesto a la renta."]]></expression>
		</element>
