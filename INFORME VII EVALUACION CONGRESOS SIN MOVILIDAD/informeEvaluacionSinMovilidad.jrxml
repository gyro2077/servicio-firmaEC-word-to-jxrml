					<textElement><font fontName="Arial" size="9" isBold="true"/></textElement>
					<textFieldExpression><![CDATA["RECOMENDACIONES. -"]]></textFieldExpression>
				</textField>
				
				<textField isStretchWithOverflow="true">
					<reportElement x="0" y="15" width="555" height="50" uuid="d77124eb-7fa1-29fc-0154-103be1ced95b"/>
					<textElement textAlignment="Justified"><font fontName="Arial" size="9"/></textElement>
					<textFieldExpression><![CDATA["Se recomienda continuar con el proceso de subvención para la publicación de los artículos titulados: “Proposed Architecture for a Patient Classification System in the Triage Process”, “Building Management System Control for Home Automation with HDL Buspro” y “White Balance Adjustment in Hyperspectral Images through Statistical Analysis” presentados por el Ing. David Rivas-Lalaleo, PhD. La solicitud cumple con todos los requisitos reglamentarios y normativos establecidos, así como con los lineamientos y procedimientos vigentes."]]></textFieldExpression>
				</textField>

