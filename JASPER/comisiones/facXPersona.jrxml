	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="pxoSecuen" class="java.lang.Long">
		<defaultValueExpression><![CDATA[7789]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select cms_codigo, personal.f_nombre(per_secuen) nombre,
   (select per_cedula from personal.pper_persona where per_secuen = pxo.per_secuen) cedula,
   (select per_cedula from personal.pper_persona where per_secuen = pxo.per_secuen) cedula_firmante,
   (case fac_tipo when 'A' then 'ALIMENTACIÓN' when 'H' then 'HOSPEDAJE'
                  when 'V' then 'VISA' when 'F' then 'FORMULARIO' END) as fac_tipo,
fac_fecha, pro_nombre, pro_identifi, fac_numdoc, fac_base0, fac_base12, fac_iva, fac_total,
(case when fac_base12 > 0 then round(((fac_iva/fac_base12)*100),0) else (case when fac_fecha > '2024-03-31'::date then 15 else 12 end) end) as poriva,
pxo_numero
 from comisiones.cfac_facturas fac, comisiones.cpxo_persoper pxo,
      activos.apro_proveedor pro, comisiones.cord_operacion ord
   where fac.pxo_secuen = pxo.pxo_secuen
     and fac.pro_secuen = pro.pro_secuen
     and pxo.cms_secuen = ord.cms_secuen
     and fac.pxo_secuen = $P{pxoSecuen}
     order by fac_tipo, fac_fecha]]>
	</queryString>
