<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="repIndividualComisiones" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="a20987a9-4dbd-4ff9-a43a-74d33ce5d800">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA["    and pxo.per_secuen = 894  group by 1, 2, 3, 4, 5, 6, 7, 8 order by 1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select (select min(dxr_fecsal) from comisiones.cdxr_detruta dxr
   where cxr_secuen = cxr_secuen_pag) cms_fecini,
   (select max(dxr_feclle) from comisiones.cdxr_detruta dxr
   where cxr_secuen = cxr_secuen_pag) feclle, per_cedula,
 (case when gmi.fue_secuen = 6 then (select esp_abrevi from personal.pesp_especial where esp_secuen = per.esp_secuen) else gmi.gmi_abreviat end) || '. ' ||
 per_apellido || ' ' || per_nombre nombre, (   case when length(split_part(cms_lugar,',',1)) > 0
     then (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',1)) else '' end ||
     case when length(split_part(cms_lugar,',',2)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',2)) else '' end ||
     case when length(split_part(cms_lugar,',',3)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',3)) else '' end ||
     case when length(split_part(cms_lugar,',',4)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',4)) else '' end ||
     case when length(split_part(cms_lugar,',',5)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',5)) else '' end
) cms_lugar, cms_codigo,
       (case when pxo.cat_secuen_est is null then (select cat_nombre from seguridades.scat_catalogo
 where cat_secuen = (select cat_secuen from comisiones.cgxo_grupoper
   where cms_secuen = pxo.cms_secuen and gdo_secuen = (select gdo_secuen from personal.pfun_funcion fun, personal.puni_unidad uni
   where fun.uni_secuen = uni.uni_secuen
     and fun.fun_secuen = pxo.fun_secuen)))
       else (select cat_nombre from seguridades.scat_catalogo where cat_secuen = pxo.cat_secuen_est) end) estado, ((case when pxo_devsub > 0 then pxo_devsub else 0 end) + (case when pxo_devali > 0 then pxo_devali else 0 end)) totdev,
       sum(round((dxr.dxr_coef * dxr.dxr_diavia * pxo.pxo_valvia)::numeric,2)) totvia,
       sum(round((dxr.dxr_coef * dxr.dxr_diavia85 * pxo.pxo_valvia85)::numeric,2)) totvia85,
       sum(round((dxr.dxr_coef * dxr.dxr_diasub * pxo.pxo_valsub)::numeric,2)) totsub,
       sum(round((dxr.dxr_coef * dxr.dxr_diaali * pxo.pxo_valali)::numeric,2)) totali,
       sum(round(comisiones.f_valor_comision_individual(pxo_secuen)::numeric,2)) total
 from comisiones.cpxo_persoper pxo, personal.pper_persona per, personal.pgmi_gradomil gmi,
      comisiones.cdxr_detruta dxr, comisiones.cord_operacion ord, comisiones.ctdo_tipooper tdo
  where pxo.per_secuen = per.per_secuen
    and per.gmi_secuen = gmi.gmi_secuen
    and pxo.cxr_secuen_pag = dxr.cxr_secuen
    and pxo.cms_secuen = ord.cms_secuen
    and ord.tdo_secuen = tdo.tdo_secuen
    and pxo.pxo_estasi = 1
    and dxr_coef > 0
    $P!{sql}]]>
	</queryString>
	<field name="cms_fecini" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha inicio de la misión]]></fieldDescription>
	</field>
	<field name="feclle" class="java.sql.Timestamp"/>
	<field name="per_cedula" class="java.lang.String">
		<fieldDescription><![CDATA[Cédula]]></fieldDescription>
	</field>
	<field name="nombre" class="java.lang.String"/>
	<field name="cms_lugar" class="java.lang.String">
		<fieldDescription><![CDATA[Lugar donde realiza la misión]]></fieldDescription>
	</field>
	<field name="cms_codigo" class="java.lang.String">
		<fieldDescription><![CDATA[Código por misión]]></fieldDescription>
	</field>
	<field name="estado" class="java.lang.String"/>
	<field name="totdev" class="java.math.BigDecimal"/>
	<field name="totvia" class="java.math.BigDecimal"/>
	<field name="totvia85" class="java.math.BigDecimal"/>
	<field name="totsub" class="java.math.BigDecimal"/>
	<field name="totali" class="java.math.BigDecimal"/>
	<field name="total" class="java.math.BigDecimal"/>
	<variable name="total" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[((( $F{totvia} > 0.0 ? $F{totvia} : 0.0 ).add(( $F{totvia85} > 0.0 ? $F{totvia85} : 0.0 ))).add(( $F{totsub} > 0.0 ? $F{totsub} : 0.0 ))).add(( $F{totali} > 0.0 ? $F{totali} : 0.0 )).subtract(( $F{totdev} > 0.0 ? $F{totdev} : 0.0 ))]]></variableExpression>
	</variable>
	<variable name="totvia_1" class="java.math.BigDecimal" resetType="Column" calculation="Sum">
		<variableExpression><![CDATA[$F{totvia}]]></variableExpression>
	</variable>
