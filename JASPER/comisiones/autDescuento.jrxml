<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="autDescuento" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="30" bottomMargin="10" uuid="5f427e00-29a8-44b4-86cf-6989e157ef38">
	<property name="ireport.zoom" value="1.9487171000000014"/>
	<property name="ireport.x" value="34"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="numero" class="java.lang.Long">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="usuario" class="java.lang.String"/>
	<queryString>
		<![CDATA[Select fechaIniRut, fue_fuerza, gmi_abreviat,
       per_cedula, nombre, pxo_numero,
       pxo_valvia, pxo_valsub, pxo_valali, pxo_valvia85, pxo_sec_perope,
       pxo_devali, pxo_valorcom, codigo,
       personal.f_firmas('E',185,0,fechaIniRut::varchar) graesp,
       personal.f_firmas('N',185,0,fechaIniRut::varchar) admfin,
       personal.f_firmas('F',185,0,fechaIniRut::varchar) funfin
   from (SELECT (SELECT min(dxr_fecsal)
  FROM comisiones.ccxr_cabruta cxr, comisiones.cdxr_detruta dxr
    where cxr.cxr_secuen = dxr.cxr_secuen
      and cxr.cxr_secuen = pxo.cxr_secuen_ant) fechaIniRut, fue_fuerza, gmi_abreviat,
       per_cedula, per_apellido || ' ' || per_nombre nombre, pxo_numero,
       pxo_valvia, pxo_valsub, pxo_valali, pxo_valvia85, pxo_sec_perope,
       pxo_devali, pxo_valorcom,
       (select cms_codigo from comisiones.cord_operacion where cms_secuen = pxo.cms_secuen) as codigo
  from comisiones.cpxo_persoper pxo, personal.pper_persona per,
       personal.pgmi_gradomil gmi, personal.pfue_fuerza fue
    where pxo.per_secuen = per.per_secuen
      and per.gmi_secuen = gmi.gmi_secuen
      and gmi.fue_secuen = fue.fue_secuen
      and pxo_secuen = $P{numero}) a]]>
	</queryString>
