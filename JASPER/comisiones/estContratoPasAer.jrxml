	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String"/>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA["group by prove, anio, mes  order by anio, mes"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT (pro_nomcom || ' -->  Contrato No. ' || con_codigo) as prove, extract(year from pas_fecacu)::int anio,
       lpad((extract(month from pas_fecacu))::varchar,2,'0') ||
       (case extract(month from pas_fecacu)
          when 1 Then 'ENE' when 2 Then 'FEB' When 3 Then 'MAR' when 4 Then 'ABR'
          when 5 Then 'MAY' When 6 Then 'JUN' when 7 Then 'JUL' when 8 Then 'AGO'
          When 9 Then 'SEP' when 10 Then 'OCT' when 11 Then 'NOV' When 12 Then 'DIC' end) mes,
       sum(pas_valtic + pas_fee) as total
  FROM comisiones.cpas_pasajes pas, comisiones.ccon_contrato con,
       activos.apro_proveedor pro
   where pas.con_secuen = con.con_secuen
     and con.pro_secuen = pro.pro_secuen
     $P!{sql}]]>
	</queryString>
	<field name="prove" class="java.lang.String"/>
	<field name="anio" class="java.lang.Integer"/>
	<field name="mes" class="java.lang.String"/>
	<field name="total" class="java.math.BigDecimal"/>
	<variable name="totMes" class="java.math.BigDecimal" resetType="Group" resetGroup="mes" calculation="Sum">
		<variableExpression><![CDATA[$F{total}]]></variableExpression>
	</variable>
	<group name="anio">
		<groupExpression><![CDATA[$F{anio}]]></groupExpression>
	</group>
	<group name="mes">
		<groupExpression><![CDATA[$F{mes}]]></groupExpression>
	</group>
