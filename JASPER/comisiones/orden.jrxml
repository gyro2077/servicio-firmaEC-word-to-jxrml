	<parameter name="funcionFirma" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[5]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT personal.f_firmas('E', 185, 0, (fecha::date)::varchar) grafin,
personal.f_firmas('N', 185, 0, (fecha::date)::varchar) nomfin,
personal.f_firmas('F', 185, 0, (fecha::date)::varchar) funfin,
          numero, fecha, uni.codigo || ' - ' || uni.descripcion solicitante, ord.total,
	identificacion || ' / ' || nombreemisionpago rucben,
	ban.descripcion as banco, (Case when tipocta = 0 Then 'AHORROS' else 'CORRIENTE' End) || ' / No.' || numerocta ctano,
         (Select descripcion from util04.tipo where tabla = 'ORDENAPLICACION' and tipo = ord.tipo) as tipo,
         (select numero from finanzas14.certificacionfondos where oid = certificacionfondosoid) certif,
         ord.descripcion, elaboradopor, numeroesigef,
          (SELECT codigo1 || '  ' || descripcion FROM finanzas14.v_item_total_14 where itemoid = det.itemoid) item,
          valor, iva, det.total as dettot, virtual,
          personal.f_firmas('N',$P{funcionFirma},0,fecha::varchar) nomuni,
          personal.f_firmas('E',$P{funcionFirma},0,fecha::varchar) espuni,
          personal.f_firmas('F',$P{funcionFirma},0,fecha::varchar) fununi,
          personal.f_firmas('N',337,0,fecha::varchar) nomcoo,
          personal.f_firmas('E',337,0,fecha::varchar) espcoo,
          personal.f_firmas('F',337,0,fecha::varchar) funcoo
	FROM finanzas14.ordenaplicacion ord, finanzas14.detordenaplica det,
	     finanzas14.unidesconcentrada uni, finanzas14.enteexterno ent,
	     finanzas14.banco ban
	 where ord.oid = det.ordenaplicacionoid
       and uni.oid = ord.unidesconcentradaoid
       and ent.oid = ord.enteexternooid
       and ban.oid = ent.bancooid
       and ord.oid = 344]]>
	</queryString>
