<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="reporteCrnl." language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="72f7f0a7-49c4-441c-ac37-15a66556af5a">
	<property name="ireport.zoom" value="3.4522712143931047"/>
	<property name="ireport.x" value="786"/>
	<property name="ireport.y" value="0"/>
	<queryString>
		<![CDATA[SELECT gmi_orden,  per_antigu, gmi_abreviat, (per_apellido || ' ' || per_nombre) nombre, fue_abrevi, per_fecingre as ingcmp,
          personal.f_unidad(per.per_secuen) unidad,
          sum(case when tdo_destino = 'N' then comisiones.f_dias_persona_com(pxo.per_secuen, cxr_secuen_pag) else 0 end) as dianac,
          sum(case when tdo_destino = 'I' then comisiones.f_dias_persona_com(pxo.per_secuen, cxr_secuen_pag) else 0 end) as diaext,
(sum(case when tdo_destino = 'N' then comisiones.f_dias_persona_com(pxo.per_secuen, cxr_secuen_pag) else 0 end) +
sum(case when tdo_destino = 'I' then comisiones.f_dias_persona_com(pxo.per_secuen, cxr_secuen_pag) else 0 end)) as total
	FROM personal.pper_persona per, personal.pgmi_gradomil gmi,
	     comisiones.cpxo_persoper pxo, comisiones.cord_operacion ord,
	     comisiones.ctdo_tipooper tdo, comisiones.cciu_ciudad ciu,
	     comisiones.cpai_pais pai, personal.pfun_funcion fun,
	     personal.pfue_fuerza fue
	  where per.gmi_secuen = gmi.gmi_secuen
	    and per.per_secuen = pxo.per_secuen
	    and pxo.cms_secuen = ord.cms_secuen
	    and ord.tdo_secuen = tdo.tdo_secuen
	    and ord.ciu_secuen = ciu.ciu_secuen
	    and ciu.pai_secuen = pai.pai_secuen
	    and pxo.fun_secuen = fun.fun_secuen
	    and gmi.fue_secuen = fue.fue_secuen
	    and per_fecsalida is null
              and gmi_tipoefec = 'O'
              and fue.fue_secuen < 4
              group by 1,2,3,4,5,6,7
	    order by gmi_orden, total]]>
	</queryString>
	<field name="gmi_orden" class="java.lang.Integer"/>
	<field name="per_antigu" class="java.lang.Integer"/>
	<field name="gmi_abreviat" class="java.lang.String"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="fue_abrevi" class="java.lang.String"/>
	<field name="ingcmp" class="java.sql.Date"/>
	<field name="unidad" class="java.lang.String"/>
	<field name="dianac" class="java.lang.Long"/>
	<field name="diaext" class="java.lang.Long"/>
	<field name="total" class="java.lang.Long"/>
