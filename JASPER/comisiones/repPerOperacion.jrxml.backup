	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long"/>
	<parameter name="paramIdGrupo" class="java.lang.Integer"/>
	<parameter name="funcionFirma" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="sumilla" class="java.lang.String">
		<defaultValueExpression><![CDATA["Flores E."]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CEDULA_USUARIO" class="java.lang.String"/>
	<queryString>
		<![CDATA[select (pxo.cat_secuen || pxo.pxo_destino || pxo.pxo_fecsalgru::varchar || pxo.pxo_fecllegru::varchar) gruseg,
       (select cat_nombre from seguridades.scat_catalogo where cat_Secuen = pxo.cat_secuen) seguridad,
        pxo.pxo_fecsalgru, pxo.pxo_fecllegru, pxo_destino,
(select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) grupo,
       (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ord.tdo_secuen) || ' No. ' || cms_codigo as numcom,
       gmi_abreviat, per_cedula, per_apellido || ' ' || per_nombre as nombre, fun_funcion,
           personal.f_firmas('E',$P{funcionFirma},0,(cms_fecini::date)::varchar) graespfirma,
           personal.f_firmas('N',$P{funcionFirma},0,(cms_fecini::date)::varchar) firma,
           personal.f_firmas('F',$P{funcionFirma},0,(cms_fecini::date)::varchar) cargo,
           COALESCE((select per2.per_cedula from personal.pfun_funcion fun2 
                     join personal.pper_persona per2 on per2.per_secuen = fun2.per_secuen 
                     where fun2.fun_secuen = $P{funcionFirma} limit 1), 'NO REGISTRADA') cedula_firmante
 from comisiones.cpxo_persoper pxo, personal.pper_persona per,
      personal.pgmi_gradomil gmi, personal.pfun_funcion fun,
      personal.puni_unidad uni, comisiones.cord_operacion ord
 where pxo.per_secuen = per.per_secuen
   and per.gmi_secuen = gmi.gmi_secuen
   and pxo.fun_secuen = fun.fun_secuen
   and fun.uni_secuen = uni.uni_secuen
   and pxo.cms_secuen = ord.cms_secuen
   and pxo.cms_secuen = $P{paramIdComision}
   and uni.gdo_secuen = $P{paramIdGrupo}
   order by 1, gmi_orden, nombre]]>
	</queryString>
