	<parameter name="sello" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\sello.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select personal.f_nombre(per_secuen) nombre,
       (select cat_nombre from seguridades.scat_catalogo where cat_secuen = pxo.cat_secuen_nov) novedad
   from comisiones.cpxo_persoper pxo, comisiones.cord_operacion ord,
       personal.pfun_funcion fun, personal.puni_unidad uni
 where pxo.cms_secuen = ord.cms_secuen
   and pxo.fun_secuen = fun.fun_secuen
   and fun.uni_secuen = uni.uni_secuen
   and pxo.cms_secuen = 2688
   and uni.gdo_secuen = 6
   and pxo.pxo_fecdevol is not null]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="novedad" class="java.lang.String"/>
	<variable name="total" class="java.lang.Integer" calculation="Count">
		<variableExpression><![CDATA[$F{nombre}]]></variableExpression>
	</variable>
