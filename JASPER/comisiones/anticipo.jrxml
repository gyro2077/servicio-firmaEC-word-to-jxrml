	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long">
		<defaultValueExpression><![CDATA[13]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdGrupo" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="ciuComision" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="usuario" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="jefegrupo" class="java.lang.Long"/>
	<parameter name="P_CEDULA_USUARIO" class="java.lang.String"/>
	<queryString>
		<![CDATA[select cms_comisi, cms_fecini, cms_fecfin,
       (select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) depend, cms_codigo,
       (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ope.tdo_secuen) tipooper,
	   (select personal.f_nombre($P{jefegrupo})) jefgru,
	   (select per_cedula from personal.pper_persona where per_secuen = $P{jefegrupo}) cedula_autoridad,
        (Select ciu_ciudad || ' - ' || pai_pais
     from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
       where ciu.pai_secuen = pai.pai_secuen
         and ciu_secuen = ope.ciu_secuen) lugar,
       gmi_abreviat || '. ' || per.per_apellido || ' ' || per.per_nombre nombre, per.per_cedula,
       det.dxr_coef,
       (Select ciu_ciudad || ' - ' || pai_pais
     from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
       where ciu.pai_secuen = pai.pai_secuen
         and ciu_secuen = det.ciu_secuen) destino,
       det.dxr_diavia, pxo.pxo_valvia, round((det.dxr_coef * det.dxr_diavia * pxo.pxo_valvia),2) totvia,
       det.dxr_diavia85, pxo.pxo_valvia85, round((det.dxr_coef * det.dxr_diavia85 * pxo.pxo_valvia85),2) totvia85,
       det.dxr_diasub, pxo.pxo_valsub, round((det.dxr_coef * det.dxr_diasub * pxo.pxo_valsub)::numeric,2) totsub,
(round((det.dxr_coef * (case when det.dxr_diavia > 0.0 Then det.dxr_diavia else 0.0 end) * pxo.pxo_valvia),2) +
round((det.dxr_coef * (case when det.dxr_diavia85 > 0.0 Then det.dxr_diavia85 else 0.0 end) * pxo.pxo_valvia85),2) +
round((det.dxr_coef * (case when det.dxr_diasub > 0.0 Then det.dxr_diasub else 0.0 end) * pxo.pxo_valsub)::numeric,2)) total
   from comisiones.cpxo_persoper pxo, personal.pper_persona per,
        personal.pgmi_gradomil gmi, comisiones.cord_operacion ope,
        personal.pfun_funcion fun, personal.puni_unidad uni,
        comisiones.ccxr_cabruta cab, comisiones.cdxr_detruta det
   where pxo.per_secuen = per.per_secuen
     and per.gmi_secuen = gmi.gmi_secuen
     and pxo.cms_secuen = ope.cms_secuen
     and fun.fun_secuen = pxo.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and pxo.cxr_secuen_ant = cab.cxr_secuen
     and cab.cxr_Secuen = det.cxr_secuen
     and det.dxr_coef > 0
     and pxo.cms_secuen = $P{paramIdComision}
     and uni.gdo_secuen = $P{paramIdGrupo}
   order by gmi.gmi_orden, nombre, det.dxr_fecsal]]>
	</queryString>
