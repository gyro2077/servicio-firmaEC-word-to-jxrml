<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="opcionSalidaComExt" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="10" uuid="b4fc9b5d-8186-43d3-81b0-e0fe6e6d6f1f">
	<property name="ireport.zoom" value="1.3310000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" group by 1,2,3,4,5,6, per_fecingre order by 1, 2, 15"]]></defaultValueExpression>
	</parameter>
	<parameter name="tiempo" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[24]]></defaultValueExpression>
	</parameter>
	<parameter name="usuario" class="java.lang.String">
		<defaultValueExpression><![CDATA["USUARIO DEL SISTEMA"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT (case gmi_tipoefec when 'O' then '1. OFICIALES' when 'V' then '2. TROPA' else '3. SP.' end) gmi_tipoefec,
       (case when gmi_tipoefec = 'O' then lpad(substring(gmi_orden::varchar,1,1),2,'0') else
       lpad(gmi_orden::varchar, 2, '0') end) orden,
       (case when gmi_tipoefec = 'O' then lpad(substring(gmi_orden::varchar,1,1),2,'0') else
       lpad(gmi_orden::varchar, 2, '0') end) || gmi_abreviat gmi_abreviat,
    (per_apellido || ' ' || per_nombre) nombre, personal.f_grupo(per.per_secuen) grupo,
       lpad(extract(year from age(per_fecingre))::TEXT,2,'0') || '/' ||
    lpad(extract(month from age(per_fecingre))::TEXT,2,'0') || '/' ||
    lpad(extract(day from age(per_fecingre))::TEXT,2,'0') tiempo,
    @(-0.1*((extract(year from age(per_fecingre))*12 + extract(month from age(per_fecingre)))-48))*0.25 coefts,
    sum((case when tdo_destino = 'I' then 1 else 0 end)) salidasi,
    sum((case when tdo_destino = 'I' and pxo_valorcom > 0 then pxo_valorcom when tdo_destino = 'I' and pxo_valorcom = 0 then pxo_valorant else 0 end)) montoi,
    sum((case when tdo_destino = 'N' then 1 else 0 end)) salidasn,
    sum((case when tdo_destino = 'N' and pxo_valorcom > 0 then pxo_valorcom when tdo_destino = 'N' and pxo_valorcom = 0 then pxo_valorant else 0 end)) monton,
    sum((case when tdo_destino = 'I' then 1 else 0 end))*0.35 coefsal,
    sum(case when pxo_valorcom > 0 then pxo_valorcom else pxo_valorant end) monto,
    sum(case when pxo_valorcom > 0 then pxo_valorcom else pxo_valorant end)*0.0004 coefmon,
    (@(-0.1*((extract(year from age(per_fecingre))*12 + extract(month from age(per_fecingre)))-48))*0.25) +
    (sum((case when tdo_destino = 'I' then 1 else 0 end))*0.35) +
    (sum(case when pxo_valorcom > 0 then pxo_valorcom else pxo_valorant end)*0.0004) coef
   from personal.pper_persona per
	   LEFT JOIN comisiones.cpxo_persoper pxo on per.per_secuen = pxo.per_secuen
	   INNER JOIN personal.pgmi_gradomil gmi ON per.gmi_secuen = gmi.gmi_secuen
	   INNER JOIN personal.pfun_funcion fun ON per.fun_secuen = fun.fun_secuen
	   FULL JOIN personal.puni_unidad uni ON fun.uni_secuen = uni.uni_secuen
	   FULL JOIN personal.pgdo_grupoope gdo ON uni.gdo_secuen = gdo.gdo_secuen
	   FULL JOIN comisiones.cord_operacion ord ON pxo.cms_secuen = ord.cms_secuen
	   FULL JOIN comisiones.ctdo_tipooper tdo ON ord.tdo_secuen = tdo.tdo_secuen
     where per.per_fecsalida is null
       and per.per_apellido is not null
       $P!{sql}]]>
	</queryString>
