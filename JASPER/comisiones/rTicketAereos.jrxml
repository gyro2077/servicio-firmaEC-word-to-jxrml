	<property name="ireport.x" value="64"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" order by pro_nomcom, numcom"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String"/>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select pas_fecacu, (case when length(trim(pxo_rectif)) > 0 Then cms_codigo || '  Rect. No. ' || pxo_rectif else cms_codigo end) as numcom,
       pro_nomcom, comisiones.f_ciudadSplit(pas.pas_rutas) ruta,
       comisiones.f_aereolineas(pxo.cxr_secuen_pag) aereolinea,
       pas_salida as salida, pas_arribo as arribo,
       pas.pxo_secuen, personal.f_nombre(pxo.per_secuen),
       pas.cat_secuen, pas_numtic,
       pas_valtic, pas_fee, pas_ivafee, pas_total,
      (SELECT cat_nombre FROM seguridades.scat_catalogo where cat_secuen = pas.cat_secuen) estado,
       pas_observ, personal.f_nombre(con.per_secuen) adm, personal.f_nombre(con.per_secuen_tni) tni,
       personal.f_firmas('T',182,0,(now()::date)::text) jeflog
  from comisiones.cpas_pasajes pas, comisiones.cpxo_persoper pxo,
       comisiones.cord_operacion ord, comisiones.ccon_contrato con,
       activos.apro_proveedor pro, comisiones.ctdo_tipooper tdo
   where pas.pxo_secuen = pxo.pxo_secuen
     and pxo.cms_secuen = ord.cms_secuen
     and pas.con_secuen = con.con_secuen
     and ord.tdo_secuen = tdo.tdo_secuen
     and pro.pro_secuen = con.pro_secuen
     $P!{sql}]]>
	</queryString>
