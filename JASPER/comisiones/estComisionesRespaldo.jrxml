	<queryString>
		<![CDATA[select lpad((extract(month from gxo_fecha))::varchar,2,'0') ||
       (case extract(month from gxo_fecha)
          when 1 Then 'ENE' when 2 Then 'FEB' When 3 Then 'MAR' when 4 Then 'ABR'
          when 5 Then 'MAY' When 6 Then 'JUN' when 7 Then 'JUL' when 8 Then 'AGO'
          When 9 Then 'SEP' when 10 Then 'OCT' when 11 Then 'NOV' When 12 Then 'DIC' end) mes,
 gdo.gdo_abreviat, comisiones.f_valor_comision_grupo(gxo.cms_secuen, gxo.gdo_secuen)
 from comisiones.cgxo_grupoper gxo, personal.pgdo_grupoope gdo,
      comisiones.cord_operacion ord, comisiones.ctdo_tipooper tdo
   where gxo.gdo_secuen = gdo.gdo_secuen
     and gxo.cms_secuen = ord.cms_secuen
     and ord.tdo_secuen = tdo.tdo_secuen
     and gxo_fecha is not null
     $P!{sql}]]>
	</queryString>
