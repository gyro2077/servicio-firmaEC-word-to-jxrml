	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" and ord.tdo_secuen = 14      order by 1, 2"]]></defaultValueExpression>
	</parameter>
	<parameter name="titPrincipal" class="java.lang.String">
