	<parameter name="titulo" class="java.lang.String"/>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" order by prove, cat_nombre"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT (pro_nomcom || ' -->  Contrato No. ' || con_codigo) as prove,
       cat_nombre, (pas_valtic + pas_fee) as total, 1 as uno
  FROM comisiones.cpas_pasajes pas, comisiones.ccon_contrato con,
       activos.apro_proveedor pro, seguridades.scat_catalogo cat
   where pas.con_secuen = con.con_secuen
     and con.pro_secuen = pro.pro_secuen
     and pas.cat_secuen = cat.cat_secuen
     $P!{sql}]]>
	</queryString>
	<field name="prove" class="java.lang.String"/>
	<field name="cat_nombre" class="java.lang.String"/>
	<field name="total" class="java.math.BigDecimal"/>
	<field name="uno" class="java.lang.Integer"/>
