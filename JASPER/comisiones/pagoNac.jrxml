	</field>
	<field name="pxo_devsub" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor por de devolución de viáticos en comisiones consecutivas]]></fieldDescription>
	</field>
	<field name="pxo_devali" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor por de devolución de alimentación en comisiones consecutivas]]></fieldDescription>
	</field>
	<field name="pxo_fecoan" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha de llegada de la comisión anterior]]></fieldDescription>
