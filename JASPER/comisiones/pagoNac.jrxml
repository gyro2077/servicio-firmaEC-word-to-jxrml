	</field>
	<field name="dxr_diavia" class="java.lang.Long">
		<fieldDescription><![CDATA[Número de días de viáticos]]></fieldDescription>
	</field>
	<field name="pxo_valvia" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor del viático al 100%]]></fieldDescription>
	</field>
	<field name="totvia" class="java.math.BigDecimal"/>
	<field name="dxr_diasub" class="java.lang.Double">
		<fieldDescription><![CDATA[Número de días de subsistencias al 100% --> 1, al 85% --> 0.85]]></fieldDescription>
	</field>
	<field name="pxo_valsub" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor de la subsistencia]]></fieldDescription>
	</field>
	<field name="totsub" class="java.math.BigDecimal"/>
	<field name="dxr_diaali" class="java.lang.Long">
		<fieldDescription><![CDATA[Número de días de alimentación]]></fieldDescription>
	</field>
	<field name="pxo_valali" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor de la alimentación]]></fieldDescription>
	</field>
	<field name="totali" class="java.math.BigDecimal"/>
	<variable name="totGen" class="java.lang.Float" calculation="Sum">
		<variableExpression><![CDATA[($F{totvia} > 0.0 ? $F{totvia} : 0.0 ) +
($F{totali} > 0.0 ? $F{totali} : 0.0) +
($F{totsub} > 0.0 ? $F{totsub} : 0.0) -
($F{pxo_devsub} > 0.0 ? $F{pxo_devsub} : 0.0) -
($F{pxo_devali} > 0.0 ? $F{pxo_devali} : 0.0)]]></variableExpression>
	</variable>
