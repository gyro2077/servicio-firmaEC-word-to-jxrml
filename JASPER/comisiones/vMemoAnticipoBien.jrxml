<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="vMemoAnticipo" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="eb189f50-317f-4939-8950-aed5664255b0">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="222"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="sello" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\sello.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long"/>
	<parameter name="paramIdGrupo" class="java.lang.Integer"/>
	<parameter name="ciuComision" class="java.lang.String"/>
	<parameter name="funcionFirma" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="sumilla" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select depend, lugar, round(total::numeric,2) total, comisiones.f_numero_letras(round(total::numeric,2)) totletras, tipooper, cms_codigo,
     (select count(*)
        from comisiones.cpxo_persoper pxo, personal.pfun_funcion fun,
             personal.puni_unidad uni
         where pxo.fun_secuen = fun.fun_secuen
           and fun.uni_secuen = uni.uni_secuen
           and cms_secuen = $P{paramIdComision} and pxo_estasi = 1
           and uni.gdo_secuen = $P{paramIdGrupo})totreg,
    (select gmi_abreviat || '. '  || (case fue_secuen when 1 then 'DE ' else '' end) || esp_abrevi || '. '
        from personal.pper_persona p, personal.pgmi_gradomil g, personal.pesp_especial e
           where p.gmi_secuen = g.gmi_secuen and p.esp_secuen = e.esp_secuen and fun_secuen = 185 and p.per_fecsalida is null) graesp,
          (select initcap(per_nombre || ' ' || per_apellido) nombre from personal.pper_persona p where fun_secuen = 185 and p.per_fecsalida is null) admfin,
    (select initcap(gmi_grado)
        from personal.pper_persona p, personal.pgmi_gradomil g
           where p.gmi_secuen = g.gmi_secuen and fun_secuen = 208  and gxo_fechapro_anticipo::date >= p.per_fecingre
    and gxo_fechapro_anticipo::date <= (case when p.per_fecsalida is null then current_date::date else p.per_fecsalida end)) graespjefespp,
          (select initcap(per_nombre || ' ' || per_apellido) nombre from personal.pper_persona p where fun_secuen = 208  and gxo_fechapro_anticipo::date >= p.per_fecingre
    and gxo_fechapro_anticipo::date <= (case when p.per_fecsalida is null then current_date::date else p.per_fecsalida end)) jefespp,
(case when ($P{funcionFirma} = 17 or $P{funcionFirma} = 448)
 then (select (case fue_secuen when 6 then '' else gmi_abreviat || '. ' end) || (case fue_secuen when 1 then 'DE ' else '' end) || esp_abrevi || '. '
        from personal.pper_persona p, personal.pgmi_gradomil g, personal.pesp_especial e
           where p.gmi_secuen = g.gmi_secuen and p.esp_secuen = e.esp_secuen and
            per_Secuen = (select max(per_secuen) from comisiones.cpxo_persoper pxo where fun_secuen = $P{funcionFirma} and cms_secuen = $P{paramIdComision})) else (select (case fue_secuen when 6 then '' else gmi_abreviat || '. ' end) || (case fue_secuen when 1 then 'DE ' else '' end) || esp_abrevi || '. '
        from personal.pper_persona p, personal.pgmi_gradomil g, personal.pesp_especial e
           where p.gmi_secuen = g.gmi_secuen and p.esp_secuen = e.esp_secuen and fun_secuen = $P{funcionFirma} and p.per_fecsalida is null) end) graespFirma,
          (case when ($P{funcionFirma} = 17  or $P{funcionFirma} = 448) then
(select initcap(per_nombre || ' ' || per_apellido) nombre
             from personal.pper_persona p
               where per_secuen = (select max(per_secuen) from comisiones.cpxo_persoper pxo where fun_secuen = $P{funcionFirma} and cms_secuen = $P{paramIdComision})) else (select initcap(per_nombre || ' ' || per_apellido) nombre
             from personal.pper_persona p where fun_secuen = $P{funcionFirma} and p.per_fecsalida is null )
     end ) firma,
          (select fun_funcion from personal.pfun_funcion where fun_secuen = $P{funcionFirma}) cargo,
          gxo_fechapro_anticipo, gxo_numofiant, gxo_nummemant
from (select  (select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) depend,
              (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ope.tdo_secuen) tipooper, ope.cms_codigo,
              (Select ciu_ciudad || ' - ' || pai_pais from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
              where ciu.pai_secuen = pai.pai_secuen and ciu_secuen = ope.ciu_secuen) lugar,
              gxo_fechapro_anticipo, gxo_numofiant, gxo_nummemant,
       sum(case when (det.dxr_diavia > 0) then round((det.dxr_coef * det.dxr_diavia * pxo.pxo_valvia),2) else 0 end +
       case when (det.dxr_diavia85 > 0) then round((det.dxr_coef * det.dxr_diavia85 * pxo.pxo_valvia85),2) else 0 end +
       case when (det.dxr_diasub > 0) then round((det.dxr_coef * det.dxr_diasub * pxo.pxo_valsub)::numeric,2) else 0 end +
       case when (det.dxr_diaali > 0) then round((det.dxr_coef * det.dxr_diaali * pxo.pxo_valali),2) else 0 end) as total, count(*) totreg
   from comisiones.cpxo_persoper pxo, comisiones.cord_operacion ope,
        personal.pfun_funcion fun, personal.puni_unidad uni,
        comisiones.ccxr_cabruta cab, comisiones.cdxr_detruta det,
        comisiones.cgxo_grupoper gxo
   where pxo.cms_secuen = ope.cms_secuen
     and fun.fun_secuen = pxo.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and pxo.cxr_secuen_ant = cab.cxr_secuen
     and cab.cxr_Secuen = det.cxr_secuen
     and gxo.cms_secuen = pxo.cms_secuen
     and gxo.gdo_secuen = uni.gdo_secuen
     and pxo.pxo_estasi = 1
     and det.dxr_coef > 0
     and pxo.cms_secuen = $P{paramIdComision}
     and uni.gdo_secuen = $P{paramIdGrupo}
     group by 1,2,3,4,5,6,7) a]]>
	</queryString>
