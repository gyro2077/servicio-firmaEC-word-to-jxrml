	<parameter name="anio" class="java.lang.Integer"/>
	<parameter name="fue_secuen" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[3]]></defaultValueExpression>
	</parameter>
	<parameter name="usuario" class="java.lang.String">
		<defaultValueExpression><![CDATA["Ing. Henry Guerrón"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT per_cedula, gmi_abreviat, (per_apellido || ' ' || per_nombre) nombre,
(select fue_fuerza from personal.pfue_fuerza where fue_secuen = $P{fue_secuen}) fuerza,
  personal.f_grupo(per.per_secuen) grupo,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio}, 1) ene,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},2) feb,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},3) mar,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},4) abr,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},5) may,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},6) jun,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},7) jul,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},8) ago,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},9) sep,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},10) oct,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},11) nov,
  comisiones.f_dias_comision_anio_mes_persona(per.per_secuen, $P{anio},12) dic,
       personal.f_firmas('N',186,0,(now()::date)::text) dirope,
       personal.f_firmas('E',186,0,(now()::date)::text) espope,
       personal.f_firmas('F',186,0,(now()::date)::text) diropefun
  FROM personal.pper_persona per,  personal.pgmi_gradomil gmi
    where per.gmi_secuen = gmi.gmi_secuen
      and $P{anio} between extract(year from per_fecingre) and extract(year from (case when per_fecsalida is null then now()::date else per_fecsalida end))
      and fue_secuen = $P{fue_secuen}
      order by gmi_orden, per_apellido]]>
	</queryString>
