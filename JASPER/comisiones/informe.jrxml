	<subDataset name="Table Dataset 1" uuid="33cb47c6-d231-4ddb-a8b1-952767ee5c11"/>
	<subDataset name="detRuta" uuid="41b0d26a-952a-4aa2-ba8a-abbec79c76bc">
		<queryString>
			<![CDATA[select (case when tr.tra_tipo = 'T' Then 'TERRESTRE' when tr.tra_tipo = 'A' Then 'AEREO' END) tipo,
 tr.tra_transp,
   (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.ciu_secuen) || ' - ' ||
   (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.cci_ciu_secuen) ruta,
    de.dxr_fecsal, de.dxr_feclle
  from comisiones.cpxo_persoper op, comisiones.cdxr_detruta de,
       comisiones.ctra_transpor tr
     where op.cxr_secuen = de.cxr_secuen
       and de.tra_secuen = tr.tra_secuen
       and pxo_secuen = 3
       order by dxr_secuen]]>
		</queryString>
		<field name="tipo" class="java.lang.String"/>
		<field name="tra_transp" class="java.lang.String">
			<fieldDescription><![CDATA[Nombre del transporte]]></fieldDescription>
		</field>
		<field name="ruta" class="java.lang.String"/>
		<field name="dxr_fecsal" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[Fecha y hora de salida]]></fieldDescription>
		</field>
		<field name="dxr_feclle" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[Fecha y hora de llegada]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="selloMRL" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="ciuComision" class="java.lang.String"/>
	<parameter name="numero" class="java.lang.Long"/>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select gmi_abreviat || '. ' || per_apellido || ' ' || per_nombre nombre, per_cedula,
      (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = op.tdo_secuen) tipooper,
      (case when per_tipcue = 'A' then 'AHORRO' when per_tipcue = 'C' then 'CORRIENTE' end) tipcue, per_numecuen,
       (select ban_banco from personal.pban_banco where ban_secuen = pe.ban_secuen) banco,
       pxo_numero, pxo_secuen, pxo_observ,
       op.cms_comisi  || (case when length(trim(pxo_rectif)) > 0 Then '.  RECTIFICADO MEDIANTE ACUERDO No. ' || pxo_rectif else '.' END ) as cms_comisi,
       (ciu_ciudad || ' - ' || pai_pais ) paisciudad, pai_codigo,
       (case when tr.tra_tipo = 'T' Then 'TERRESTRE' when tr.tra_tipo = 'A' Then 'AEREO' when tr.tra_tipo = 'M' Then 'FLUVIAL' END) tipo,
       tr.tra_transp,
       (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.ciu_secuen) || ' - ' ||
       (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.cci_ciu_secuen) ruta,
       de.dxr_fecsal, de.dxr_feclle,
       (select fun_funcion from personal.pfun_funcion where fun_secuen = po.fun_secuen) funcion,
       (select gdo_grupoope
	 from personal.pfun_funcion fu, personal.puni_unidad un, personal.pgdo_grupoope gr
	    where fu.uni_secuen = un.uni_secuen
                and un.gdo_Secuen = gr.gdo_secuen
                and fun_secuen = po.fun_secuen) grupo,
	(select min(dxr_fecsal) from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag) inicio,
	(select max(dxr_feclle) from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag) fin,
	(select max(dxr_feclle) + interval '1 day' from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag) fecha_informe,
	op.cms_codigo,
           personal.f_firmas('T',893,0,(select max(dxr_feclle) + '1 days' from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag)::varchar) admfin,
           personal.f_firmas('F',893,0,(select max(dxr_feclle) + '1 days' from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag)::varchar) funadmfin,
           personal.f_firmas('R',893,0,(select max(dxr_feclle) + '1 days' from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag)::varchar) resadmfin,
          (select gxo_fecha
             from comisiones.cgxo_grupoper gxo, personal.puni_unidad uni, personal.pfun_funcion fun
               where fun.uni_secuen = uni.uni_secuen
                 and uni.gdo_secuen = gxo.gdo_secuen
                 and cms_secuen = op.cms_secuen and fun_secuen = po.fun_secuen) fecha,
     COALESCE(
        (SELECT per2.per_cedula FROM personal.pfxp_funcpers fxp2
         JOIN personal.pper_persona per2 ON fxp2.per_secuen = per2.per_secuen
         WHERE fxp2.fun_secuen = 893
         AND (select max(dxr_feclle) from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag)::date BETWEEN fxp2.fxp_fecini AND COALESCE(fxp2.fxp_fecfin, (select max(dxr_feclle) from comisiones.cdxr_detruta where cxr_secuen = po.cxr_secuen_pag)::date + 20)
         LIMIT 1),
        'NO REGISTRADA'
    ) as cedula_autoridad,
    (SELECT personal.f_nombre(cpx.per_secuen)
     FROM comisiones.cpxo_persoper cpx
     JOIN personal.pfun_funcion f ON cpx.fun_secuen = f.fun_secuen
     JOIN personal.puni_unidad u ON f.uni_secuen = u.uni_secuen
     JOIN personal.pper_persona p ON cpx.per_secuen = p.per_secuen
     JOIN personal.pgmi_gradomil g ON p.gmi_secuen = g.gmi_secuen
     WHERE cpx.cms_secuen = po.cms_secuen
       AND cpx.pxo_estope = 1 AND cpx.pxo_numero IS NOT NULL
       AND u.gdo_secuen = (
           SELECT u2.gdo_secuen
           FROM personal.pfun_funcion f2
           JOIN personal.puni_unidad u2 ON f2.uni_secuen = u2.uni_secuen
           WHERE f2.fun_secuen = po.fun_secuen
       )
     ORDER BY g.gmi_orden, p.per_apellido LIMIT 1) as jefgru,
    (SELECT p.per_cedula
     FROM comisiones.cpxo_persoper cpx
     JOIN personal.pfun_funcion f ON cpx.fun_secuen = f.fun_secuen
     JOIN personal.puni_unidad u ON f.uni_secuen = u.uni_secuen
     JOIN personal.pper_persona p ON cpx.per_secuen = p.per_secuen
     JOIN personal.pgmi_gradomil g ON p.gmi_secuen = g.gmi_secuen
     WHERE cpx.cms_secuen = po.cms_secuen
       AND cpx.pxo_estope = 1 AND cpx.pxo_numero IS NOT NULL
       AND u.gdo_secuen = (
           SELECT u2.gdo_secuen
           FROM personal.pfun_funcion f2
           JOIN personal.puni_unidad u2 ON f2.uni_secuen = u2.uni_secuen
           WHERE f2.fun_secuen = po.fun_secuen
       )
     ORDER BY g.gmi_orden, p.per_apellido LIMIT 1) as cedula_jefgru
from comisiones.cpxo_persoper po, personal.pper_persona pe,
     personal.pgmi_gradomil gr, comisiones.cord_operacion op,
     comisiones.cciu_ciudad ci, comisiones.cpai_pais pa,
     comisiones.cdxr_detruta de, comisiones.ctra_transpor tr
 where po.per_secuen = pe.per_secuen
   and pe.gmi_secuen = gr.gmi_secuen
   and po.cms_secuen = op.cms_secuen
   and op.ciu_secuen = ci.ciu_secuen
   and ci.pai_secuen = pa.pai_secuen
   and po.cxr_secuen_pag = de.cxr_secuen
   and de.tra_secuen = tr.tra_secuen
   and pxo_secuen = $P{numero}
   order by de.dxr_fecsal]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="per_cedula" class="java.lang.String"/>
	<field name="tipooper" class="java.lang.String"/>
	<field name="tipcue" class="java.lang.String"/>
	<field name="per_numecuen" class="java.lang.String">
