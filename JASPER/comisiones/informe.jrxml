	</field>
	<field name="admfin" class="java.lang.String"/>
	<field name="funadmfin" class="java.lang.String"/>
	<field name="resadmfin" class="java.lang.String"/>
	<field name="fecha" class="java.sql.Timestamp"/>
	<field name="cedula_autoridad" class="java.lang.String"/>
	<field name="jefgru" class="java.lang.String"/>
	<field name="cedula_jefgru" class="java.lang.String"/>
