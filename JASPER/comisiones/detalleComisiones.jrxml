	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT cms_codigo, cms_fecini, cms_fecfin, pai_pais, per_cedula, personal.f_nombre(pxo.per_secuen) nombre, fun_funcion, personal.f_unidad(pxo.per_secuen,'N') unidad
  FROM comisiones.cord_operacion ord, comisiones.ctdo_tipooper tdo,
       comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai,
       comisiones.cpxo_persoper pxo, personal.pper_persona per,
       personal.pfun_funcion fun, personal.pgmi_gradomil gmi
    where ord.tdo_secuen = tdo.tdo_secuen
      and ord.ciu_secuen = ciu.ciu_secuen
      and ciu.pai_secuen = pai.pai_secuen
      and ord.cms_secuen = pxo.cms_secuen
      and pxo.per_secuen = per.per_secuen
      and pxo.fun_secuen = fun.fun_secuen
      and per.gmi_secuen = gmi.gmi_secuen
      and tdo.tdo_secuen = 5
      and substring(cms_codigo,5,4)::INT between 2015 and 2017
      order by cms_codigo, gmi_orden]]>
	</queryString>
	<field name="cms_codigo" class="java.lang.String">
		<fieldDescription><![CDATA[Código por misión]]></fieldDescription>
	</field>
	<field name="cms_fecini" class="java.sql.Timestamp">
