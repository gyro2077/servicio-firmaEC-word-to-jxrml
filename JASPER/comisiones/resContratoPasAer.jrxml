	<queryString>
		<![CDATA[select pro_nomcom, con_codigo, con_valor::float, (case when (SELECT sum(pas_total) from comisiones.cpas_pasajes where con_secuen = con.con_secuen) > 0 then
(SELECT sum(pas_valtic+pas_fee) from comisiones.cpas_pasajes where con_secuen = con.con_secuen) else 0.00 end)::float pagado
  from comisiones.ccon_contrato con, activos.apro_proveedor pro
   where con.pro_secuen = pro.pro_secuen
     $P!{sql}]]>
	</queryString>
	<field name="pro_nomcom" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre comercial]]></fieldDescription>
	</field>
	<field name="con_codigo" class="java.lang.String">
