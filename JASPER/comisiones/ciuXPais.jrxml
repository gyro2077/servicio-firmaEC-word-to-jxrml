	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="codPais" class="java.lang.Long"/>
	<queryString>
		<![CDATA[SELECT pai_pais, ciu_ciudad
	FROM comisiones.cpai_pais pai,
	     comisiones.cciu_ciudad ciu
	 where pai.pai_secuen = ciu.pai_secuen
             and pai.pai_secuen = $P{codPais}
	   order by 1,2]]>
	</queryString>
