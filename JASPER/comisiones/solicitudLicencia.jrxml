	<subDataset name="Table Dataset 1" uuid="33cb47c6-d231-4ddb-a8b1-952767ee5c11"/>
	<subDataset name="detRuta" uuid="41b0d26a-952a-4aa2-ba8a-abbec79c76bc">
		<queryString>
			<![CDATA[select (case when tr.tra_tipo = 'T' Then 'TERRESTRE' when tr.tra_tipo = 'A' Then 'AEREO' END) tipo,
 tr.tra_transp,
   (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.ciu_secuen) || ' - ' ||
   (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.cci_ciu_secuen) ruta,
    de.dxr_fecsal, de.dxr_feclle
  from comisiones.cpxo_persoper op, comisiones.cdxr_detruta de,
       comisiones.ctra_transpor tr
     where op.cxr_secuen = de.cxr_secuen
       and de.tra_secuen = tr.tra_secuen
       and pxo_secuen = 3
       order by dxr_secuen]]>
		</queryString>
		<field name="tipo" class="java.lang.String"/>
		<field name="tra_transp" class="java.lang.String">
			<fieldDescription><![CDATA[Nombre del transporte]]></fieldDescription>
		</field>
		<field name="ruta" class="java.lang.String"/>
		<field name="dxr_fecsal" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[Fecha y hora de salida]]></fieldDescription>
		</field>
		<field name="dxr_feclle" class="java.sql.Timestamp">
			<fieldDescription><![CDATA[Fecha y hora de llegada]]></fieldDescription>
		</field>
	</subDataset>
	<parameter name="numero" class="java.lang.Long"/>
	<queryString>
		<![CDATA[select gmi_abreviat || '. ' || per_apellido || ' ' || per_nombre nombre,
       per_cedula,(case when per_tipcue = 'A' then 'AHORRO' when per_tipcue = 'C' then 'CORRIENTE' end) tipcue, per_numecuen,
       (select ban_banco from personal.pban_banco where ban_secuen = pe.ban_secuen) banco,
       pxo_numero, pxo_secuen, op.cms_fecini, cms_fecfin,
       (ciu_ciudad || ' - ' || pai_pais ) paisciudad, pai_codigo,
       (case when tr.tra_tipo = 'T' Then 'TERRESTRE' when tr.tra_tipo = 'A' Then 'AEREO' END) tipo,
       tr.tra_transp,
       (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.ciu_secuen) || ' - ' ||
       (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen = de.cci_ciu_secuen) ruta,
       de.dxr_fecsal, de.dxr_feclle
from comisiones.cpxo_persoper po, personal.pper_persona pe,
     personal.pgmi_gradomil gr, comisiones.cord_operacion op,
     comisiones.cciu_ciudad ci, comisiones.cpai_pais pa,
     comisiones.cdxr_detruta de, comisiones.ctra_transpor tr
 where po.per_secuen = pe.per_secuen
   and pe.gmi_secuen = gr.gmi_secuen
   and po.cms_secuen = op.cms_secuen
   and op.ciu_secuen = ci.ciu_secuen
   and ci.pai_secuen = pa.pai_secuen
   and po.cxr_secuen_pag = de.cxr_secuen
   and de.tra_secuen = tr.tra_secuen
   and pxo_secuen = $P{numero}
   order by de.dxr_secuen]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="per_cedula" class="java.lang.String">
		<fieldDescription><![CDATA[Cédula]]></fieldDescription>
	</field>
	<field name="tipcue" class="java.lang.String"/>
	<field name="per_numecuen" class="java.lang.String">
		<fieldDescription><![CDATA[Número de cuenta bancaria]]></fieldDescription>
	</field>
	<field name="banco" class="java.lang.String"/>
	<field name="pxo_numero" class="java.lang.String"/>
	<field name="pxo_secuen" class="java.lang.Long">
		<fieldDescription><![CDATA[Secuencial del listado de personas]]></fieldDescription>
	</field>
	<field name="cms_fecini" class="java.sql.Date">
		<fieldDescription><![CDATA[Fecha inicio de la misión]]></fieldDescription>
	</field>
	<field name="cms_fecfin" class="java.sql.Date">
		<fieldDescription><![CDATA[Fecha fin de la misión]]></fieldDescription>
	</field>
	<field name="paisciudad" class="java.lang.String"/>
	<field name="pai_codigo" class="java.lang.String">
		<fieldDescription><![CDATA[Código del país]]></fieldDescription>
	</field>
	<field name="tipo" class="java.lang.String"/>
	<field name="tra_transp" class="java.lang.String">
		<fieldDescription><![CDATA[Nombre del transporte]]></fieldDescription>
	</field>
	<field name="ruta" class="java.lang.String"/>
	<field name="dxr_fecsal" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha y hora de salida]]></fieldDescription>
	</field>
	<field name="dxr_feclle" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha y hora de llegada]]></fieldDescription>
	</field>
