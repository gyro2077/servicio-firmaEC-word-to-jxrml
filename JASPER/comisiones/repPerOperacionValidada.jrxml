	<parameter name="P_CEDULA_USUARIO" class="java.lang.String"/>
	<queryString>
		<![CDATA[select (pxo.cat_secuen || pxo.pxo_destino || pxo.pxo_fecsalgru::varchar || pxo.pxo_fecllegru::varchar) gruseg,
	(select cat_nombre from seguridades.scat_catalogo where cat_Secuen = pxo.cat_secuen) seguridad,
	pxo.pxo_fecsalgru, pxo.pxo_fecllegru, pxo_destino,
	(select gdo_secuen from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) ordenGrupo,
	(select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) grupo,
	(select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ord.tdo_secuen) || ' No. ' || cms_codigo as numcom,
	gmi_abreviat, per_cedula, per_apellido || ' ' || per_nombre as nombre, fun_funcion,
	personal.f_firmas('N',$P{funcionFirma},$P{paramIdComision},(cms_fecmem::date)::varchar) firma,
	personal.f_firmas('E',$P{funcionFirma},$P{paramIdComision},(cms_fecmem::date)::varchar) graespfirma,
	personal.f_firmas('F',$P{funcionFirma},0,(cms_fecmem::date)::varchar) cargo,
	upper(personal.f_firmas('N',187,0,(cms_fecmem::date)::varchar)) nombreth,
	personal.f_firmas('E',187,0,(cms_fecmem::date)::varchar) graespth,
	personal.f_firmas('F',187,0,(cms_fecmem::date)::varchar) cargoth,
	personal.f_firmas('G',187,0,(cms_fecmem::date)::varchar) gradoth,
	upper(personal.f_firmas('N',185,0,(cms_fecmem::date)::varchar)) nombrefin,
	personal.f_firmas('E',185,0,(cms_fecmem::date)::varchar) graespfin,
	personal.f_firmas('F',185,0,(cms_fecmem::date)::varchar) cargofin,
	personal.f_firmas('G',185,0,(cms_fecmem::date)::varchar) gradofin,
	comisiones.f_memoPara($P{paramIdComision}) para,
	ord.cms_comisi, ord.cms_nummem, ord.cms_fecmem::date,
	personal.f_firmas('M',186,0,(cms_fecmem::date)::varchar) sumJefOpe,
	COALESCE((SELECT per2.per_cedula FROM personal.pfxp_funcpers fxp2 JOIN personal.pper_persona per2 ON fxp2.per_secuen = per2.per_secuen WHERE fxp2.fun_secuen = 186 AND (cms_fecmem::date) BETWEEN fxp2.fxp_fecini AND COALESCE(fxp2.fxp_fecfin, (cms_fecmem::date) + 20) LIMIT 1), 'NO REGISTRADA') cedula_jefe,
	COALESCE((SELECT per2.per_cedula FROM personal.pfxp_funcpers fxp2 JOIN personal.pper_persona per2 ON fxp2.per_secuen = per2.per_secuen WHERE fxp2.fun_secuen = $P{funcionFirma} AND (cms_fecmem::date) BETWEEN fxp2.fxp_fecini AND COALESCE(fxp2.fxp_fecfin, (cms_fecmem::date) + 20) LIMIT 1), 'NO REGISTRADA') cedula_autoridad
	from comisiones.cpxo_persoper pxo, personal.pper_persona per,
	personal.pgmi_gradomil gmi, personal.pfun_funcion fun,
	personal.puni_unidad uni, comisiones.cord_operacion ord
	where pxo.per_secuen = per.per_secuen
	and per.gmi_secuen = gmi.gmi_secuen
	and pxo.fun_secuen = fun.fun_secuen
	and fun.uni_secuen = uni.uni_secuen
	and pxo.cms_secuen = ord.cms_secuen
	and pxo.pxo_numero is not null
	and pxo.cms_secuen = $P{paramIdComision}
	and (case when $P{paramIdGrupo} = 0 then 1 = 1 else uni.gdo_secuen = $P{paramIdGrupo} end)
	order by ordenGrupo, 1, gmi_orden, nombre]]>
	</queryString>
