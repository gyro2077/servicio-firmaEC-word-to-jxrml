	</parameter>
	<queryString>
		<![CDATA[select (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ord.tdo_secuen) tipo, cms_codigo,
       (select gdo_abreviat from personal.pfun_funcion fun, personal.puni_unidad uni, personal.pgdo_grupoope gdo
        where fun.uni_secuen = uni.uni_secuen
          and uni.gdo_secuen = gdo.gdo_secuen
          and fun_secuen = pxo.fun_secuen) grupo,
(   case when length(split_part(cms_lugar,',',1)) > 0
     then (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',1)) else '' end ||
     case when length(split_part(cms_lugar,',',2)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',2)) else '' end ||
     case when length(split_part(cms_lugar,',',3)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',3)) else '' end||
     case when length(split_part(cms_lugar,',',4)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',4)) else '' end
) cms_lugar,
          gmi_abreviat || '. ' || per_apellido || ' ' || per_nombre nombre,
      (select cat_nombre from seguridades.scat_catalogo where cat_secuen = pxo.cat_secuen_nov) novedad,
      gxo_fecentfin, pxo_fecdevol, pxo.pxo_feccompr, pxo.pxo_fecdeven, pxo.pxo_fecpago ,
      pxo.pxo_valorcom total, cms_fecini, cms_fecfin,
(SELECT min(dxr_fecsal)
  FROM comisiones.ccxr_cabruta cxr, comisiones.cdxr_detruta dxr
  Where cxr.cxr_secuen = dxr.cxr_secuen
    and cxr.cxr_secuen = pxo.cxr_secuen_pag) salida,
(SELECT max(dxr_feclle)
  FROM comisiones.ccxr_cabruta cxr, comisiones.cdxr_detruta dxr
  Where cxr.cxr_secuen = dxr.cxr_secuen
    and cxr.cxr_secuen = pxo.cxr_secuen_pag) llegada
 from comisiones.cpxo_persoper pxo, personal.pper_persona per, personal.pgmi_gradomil gmi,
      comisiones.cord_operacion ord, comisiones.cgxo_grupoper gxo
    where pxo.per_secuen = per.per_secuen
      and per.gmi_secuen = gmi.gmi_secuen
      and pxo.cms_secuen = ord.cms_secuen
      and pxo.cms_secuen = gxo.cms_secuen
      and gxo.gdo_secuen = (select gdo.gdo_secuen from personal.pfun_funcion fun, personal.puni_unidad uni, personal.pgdo_grupoope gdo
        where fun.uni_secuen = uni.uni_secuen
          and uni.gdo_secuen = gdo.gdo_secuen
          and fun_secuen = pxo.fun_secuen)
      and gxo_fecentfin is not null
and extract(year from cms_fecini) = 2022 and tdo_secuen = 5
      order by 1, 2, 3, gmi.gmi_orden]]>
	</queryString>
