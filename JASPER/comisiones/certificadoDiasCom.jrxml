		<defaultValueExpression><![CDATA["c:\\sello.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="secPers" class="java.lang.Long">
		<defaultValueExpression><![CDATA[1296]]></defaultValueExpression>
