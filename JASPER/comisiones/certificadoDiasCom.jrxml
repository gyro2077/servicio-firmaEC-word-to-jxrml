	</parameter>
	<queryString>
		<![CDATA[select personal.f_nombre(per_secuen) nombre, per_cedula,
 comisiones.f_dias_comision_persona(per_secuen) dias,
   to_char(per_fecingre::date,'DD-MM-YYYY') per_fecingre, to_char(per_fecsalida::date,'DD-MM-YYYY') per_fecsalida,
   Upper(personal.f_firmas('N',208,0,(now()::date)::varchar)) firmaJSPP,
   personal.f_firmas('E',208,0,(now()::date)::varchar) gradoJSPP,
   personal.f_firmas('F',208,0,(now()::date)::varchar) cargoJSPP,
   upper(personal.f_firmas('N',186,0,(now()::date)::varchar)) firmaOpe,
   personal.f_firmas('E',186,0,(now()::date)::varchar) gradoOpe,
   personal.f_firmas('F',186,0,(now()::date)::varchar) cargoOpe
 from personal.pper_persona  where per_secuen = $P{secPers}]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="per_cedula" class="java.lang.String"/>
	<field name="dias" class="java.lang.Integer"/>
	<field name="per_fecingre" class="java.lang.String">
