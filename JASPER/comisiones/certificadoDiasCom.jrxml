			</textField>
			<textField>
				<reportElement uuid="e0f34df2-3abb-4819-bc99-8fa055735c7e" x="52" y="31" width="450" height="32"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["El Sr. " + $F{gradojspp} + " " + $F{firmajspp} +", Jefe de la Casa Militar Presidencial, a petición del interesado certifica que:"]]></textFieldExpression>
			</textField>
