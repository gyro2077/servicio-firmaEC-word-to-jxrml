	<detail>
		<band height="361" splitType="Stretch">
			<textField>
				<reportElement uuid="94240fe0-7ae9-49d9-9e80-893069f9e477" x="52" y="0" width="450" height="79"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["Consta en los registros de la base de datos de la CMP, con el cumplimiento de (" + $F{dias}
+ ") días de operaciones de Inteligencia (seguridad a las máximas autoridades del país y sus familiares íntimos), desde el "
+ $F{per_fecingre} + ", hasta "
+ ( $F{per_fecsalida} != null ? "el " + $F{per_fecsalida} + "." : "la presente. " )]]></textFieldExpression>
			</textField>
			<staticText>
				<reportElement uuid="c4a92a15-7205-44db-ace3-65762cceffca" x="52" y="89" width="450" height="24"/>
				<textElement/>
				<text><![CDATA[El uso del presente certificado, será de responsabilidad exclusiva del solicitante.]]></text>
			</staticText>
