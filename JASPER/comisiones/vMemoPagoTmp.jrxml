	<detail>
		<band height="112" splitType="Stretch">
			<textField>
				<reportElement uuid="9a1193fe-6bad-44f1-af50-103a94921a59" x="0" y="0" width="380" height="94"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["Adjunto al presente me permito remitir a usted mi General, el cálculo de viáticos y subsistencias del personal de " + $F{depend} + " que cumplieron la comisión de servicios en " + $P{ciuComision} + "; SEGÚN " + $F{tipooper} + " No. " + $F{cms_codigo} + ", a fin de que se digne autorizar y disponer a quien corresponda se realicen los trámites pertinentes."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement uuid="d3b683f9-cb84-474a-9aed-9f18a9bd9963" x="422" y="0" width="380" height="94"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["Agradeceré a usted señor Mayor, se sirva disponer a quien corresponda, se realice el pago por concepto de viáticos y subsistencias por el valor de " + $F{total} + " (" + $F{totletras} +"), a favor del personal de " + $F{depend} + ", que cumplieron la comisión de servicios en " + $P{ciuComision} + "; SEGUN " + $F{tipooper} + " No. " + $F{cms_codigo} + ", para lo cual adjunto la documentación respectiva."]]></textFieldExpression>
			</textField>
		</band>
	</detail>
