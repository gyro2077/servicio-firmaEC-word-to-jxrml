			<staticText>
				<reportElement uuid="f08a6534-9d6d-4cdf-ba57-0774cbca48b1" x="2" y="101" width="274" height="19"/>
				<textElement verticalAlignment="Middle">
					<font size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[AUXILIAR LOGÍSTICO]]></text>
			</staticText>
			<staticText>
				<reportElement uuid="b7986c53-231a-4fad-841c-535cd0fd3405" x="0" y="71" width="274" height="19"/>
				<textElement verticalAlignment="Middle">
					<font size="10" isBold="true"/>
				</textElement>
				<text><![CDATA[Henry Parra]]></text>
