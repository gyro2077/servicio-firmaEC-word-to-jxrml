		<fieldDescription><![CDATA[Fecha inicio de la misión]]></fieldDescription>
	</field>
	<field name="cms_fecfin" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha fin de la misión]]></fieldDescription>
	</field>
	<field name="pxo_secuen" class="java.lang.Long">
		<fieldDescription><![CDATA[persona por operación]]></fieldDescription>
	</field>
	<field name="f_nombre" class="java.lang.String"/>
	<field name="cat_secuen" class="java.lang.Integer">
		<fieldDescription><![CDATA[Presentación del artículo]]></fieldDescription>
	</field>
	<field name="pas_numtic" class="java.lang.String">
		<fieldDescription><![CDATA[número ticket]]></fieldDescription>
	</field>
	<field name="pas_valtic" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor del ticket]]></fieldDescription>
	</field>
	<field name="pas_fee" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Pago para la prestación de servicios efectuados por las agencias de viajes]]></fieldDescription>
	</field>
	<field name="pas_ivafee" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Iva del fee]]></fieldDescription>
	</field>
	<field name="pas_total" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor total del pasaje aéreo]]></fieldDescription>
	</field>
	<field name="estado" class="java.lang.String"/>
	<field name="pas_observ" class="java.lang.String">
		<fieldDescription><![CDATA[Observación del pasaje aéreo]]></fieldDescription>
	</field>
