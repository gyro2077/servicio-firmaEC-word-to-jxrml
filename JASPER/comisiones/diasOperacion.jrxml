	<property name="ireport.zoom" value="1.4641000000000006"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="anio" class="java.lang.Integer"/>
	<parameter name="fue_secuen" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[3]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT per_cedula, gmi_abreviat, esp_abrevi, (per_apellido || ' ' || per_nombre) nombre, per_fecingre, per_fecsalida,
(select fue_fuerza from personal.pfue_fuerza where fue_secuen = $P{fue_secuen}) fuerza,
  comisiones.f_dias_comision_anio_persona(per.per_secuen, $P{anio}) dias,
       personal.f_firmas('N',186,0,(now()::date)::text) dirope,
       personal.f_firmas('E',186,0,(now()::date)::text) espope,
       personal.f_firmas('F',186,0,(now()::date)::text) diropefun
  FROM personal.pper_persona per,  personal.pgmi_gradomil gmi, personal.pesp_especial esp
    where per.gmi_secuen = gmi.gmi_secuen
      and per.esp_secuen = esp.esp_secuen
      and $P{anio} between extract(year from per_fecingre) and extract(year from (case when per_fecsalida is null then now()::date else per_fecsalida end))
      and fue_secuen = $P{fue_secuen}
      order by gmi_orden, per_apellido]]>
	</queryString>
