				<textFieldExpression><![CDATA["Adjunto al presente remito a usted señor(a). " + $F{gra} + ", la orden de gasto No. " + $F{gxo_ordgasto} + " con la documentación correspondiente al pago de viáticos " + ( $F{cms_fecfin} != null && String.valueOf($F{cms_fecfin}).length() >= 10 && String.valueOf($F{cms_fecfin}).substring(0, 10).compareTo("2016-03-30") <= 0 ? " y subsistencias " : "" ) + ", a fin de que se digne disponer a quien corresponda realice el trámite necesario de acuerdo al siguiente detalle:"]]></textFieldExpression>
