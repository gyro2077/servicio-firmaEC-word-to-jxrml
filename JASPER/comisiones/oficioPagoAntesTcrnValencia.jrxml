	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long"/>
	<parameter name="paramIdGrupo" class="java.lang.Integer"/>
	<parameter name="paramObsOfi" class="java.lang.String">
		<defaultValueExpression><![CDATA["Probando descripción"]]></defaultValueExpression>
	</parameter>
