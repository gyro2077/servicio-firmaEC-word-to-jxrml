<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="repIndividualComisiones" language="groovy" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="a20987a9-4dbd-4ff9-a43a-74d33ce5d800">
	<property name="ireport.zoom" value="1.3310000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["    and pxo.per_secuen = 2713 group by 1, 2, 3, 4, 5, 6, 7, 8 order by 1"]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="marca" class="java.lang.String">
		<defaultValueExpression><![CDATA["poner20caracteres123"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select (case when (select count(*) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_pag) > 0 then
       (select min(dxr_fecsal) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_pag) else
       (select min(dxr_fecsal) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_ant) end)  fecsal,
       (case when (select count(*) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_pag) > 0 then
       (select max(dxr_feclle) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_pag) else
       (select max(dxr_feclle) from comisiones.cdxr_detruta dxr where cxr_secuen = cxr_secuen_ant) end)  feclle, per_cedula,
 (case when gmi.fue_secuen = 6 then (select esp_abrevi from personal.pesp_especial where esp_secuen = per.esp_secuen) else gmi.gmi_abreviat end) || '. ' ||
 per_apellido || ' ' || per_nombre nombre, (   case when length(split_part(cms_lugar,',',1)) > 0
     then (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',1)) else '' end ||
     case when length(split_part(cms_lugar,',',2)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',2)) else '' end ||
     case when length(split_part(cms_lugar,',',3)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',3)) else '' end ||
     case when length(split_part(cms_lugar,',',4)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',4)) else '' end ||
     case when length(split_part(cms_lugar,',',5)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',5)) else '' end
) cms_lugar, cms_codigo,
       (case when pxo.cat_secuen_est is null then (select cat_nombre from seguridades.scat_catalogo
 where cat_secuen = (select cat_secuen from comisiones.cgxo_grupoper
   where cms_secuen = pxo.cms_secuen and gdo_secuen = (select gdo_secuen from personal.pfun_funcion fun, personal.puni_unidad uni
   where fun.uni_secuen = uni.uni_secuen
     and fun.fun_secuen = pxo.fun_secuen)))
       else (select cat_nombre from seguridades.scat_catalogo where cat_secuen = pxo.cat_secuen_est) end) estado,
       (case when pxo_valorcom is null then 0 else pxo_valorcom end) pxo_valorcom
 from comisiones.cpxo_persoper pxo, personal.pper_persona per, personal.pgmi_gradomil gmi,
      comisiones.cord_operacion ord, comisiones.ctdo_tipooper tdo
  where pxo.per_secuen = per.per_secuen
    and per.gmi_secuen = gmi.gmi_secuen
    and pxo.cms_secuen = ord.cms_secuen
    and ord.tdo_secuen = tdo.tdo_secuen
    $P!{sql}]]>
	</queryString>
	<field name="fecsal" class="java.sql.Timestamp"/>
	<field name="feclle" class="java.sql.Timestamp"/>
	<field name="per_cedula" class="java.lang.String"/>
	<field name="nombre" class="java.lang.String"/>
	<field name="cms_lugar" class="java.lang.String"/>
	<field name="cms_codigo" class="java.lang.String"/>
	<field name="estado" class="java.lang.String"/>
	<field name="pxo_valorcom" class="java.math.BigDecimal"/>
	<variable name="pxo_valorcom_1" class="java.math.BigDecimal" calculation="Sum">
		<variableExpression><![CDATA[$F{pxo_valorcom}]]></variableExpression>
	</variable>
