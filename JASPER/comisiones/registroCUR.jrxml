	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="usuario" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" and pxo.pxo_fecpago::date >= '2020-01-13'::date and pxo.pxo_fecpago::date <= '2020-01-13'::date order by 4 "]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select personal.f_nombre(pxo.per_secuen) nombre,
   cms_codigo comision,
 pxo_valorcom, pxo_cur::numeric
 from comisiones.cpxo_persoper pxo, comisiones.cord_operacion ord,
      personal.pfun_funcion fun, personal.puni_unidad uni,
      personal.pgdo_grupoope gdo, comisiones.cgxo_grupoper gxo
   where pxo.cms_secuen = ord.cms_secuen
     and pxo.fun_secuen = fun.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and uni.gdo_secuen = gdo.gdo_secuen
     and pxo.cms_secuen = gxo.cms_secuen
     and gdo.gdo_secuen = gxo.gdo_secuen
     and pxo_cur is not null
     $P!{sql}]]>
	</queryString>
	<field name="nombre" class="java.lang.String"/>
	<field name="comision" class="java.lang.String"/>
	<field name="pxo_valorcom" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Valor calculado solo por comisión]]></fieldDescription>
	</field>
	<field name="pxo_cur" class="java.math.BigDecimal">
		<fieldDescription><![CDATA[Cur de devengado]]></fieldDescription>
	</field>
