<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="repIndividualComisiones" language="groovy" pageWidth="842" pageHeight="595" orientation="Landscape" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="a20987a9-4dbd-4ff9-a43a-74d33ce5d800">
	<property name="ireport.zoom" value="1.3310000000000004"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA["    and pxo.per_secuen = 894  group by 1, 2, 3, 4, 5, 6, 7, 8 order by 1"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT personal.f_nombre(per_secuen) nombre, cms_codigo,
(select min(dxr_fecsal) from comisiones.cdxr_detruta dxr
   where cxr_secuen = cxr_secuen_pag) cms_fecini,
   (select max(dxr_feclle) from comisiones.cdxr_detruta dxr
   where cxr_secuen = cxr_secuen_pag) feclle,
   (   case when length(split_part(cms_lugar,',',1)) > 0
     then (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',1)) else '' end ||
     case when length(split_part(cms_lugar,',',2)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',2)) else '' end ||
     case when length(split_part(cms_lugar,',',3)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',3)) else '' end ||
     case when length(split_part(cms_lugar,',',4)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',4)) else '' end ||
     case when length(split_part(cms_lugar,',',5)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',5)) else '' end
) cms_lugar,
(SELECT  gxo_fechapro_anticipo
  FROM comisiones.cgxo_grupoper
     where cms_secuen = pxo.cms_secuen
       and gdo_secuen = (SELECT gdo_secuen
  FROM personal.pfun_funcion fun, personal.puni_unidad uni
    where fun.uni_secuen = uni.uni_secuen
      and fun.fun_secuen = pxo.fun_secuen)) fecant,
(SELECT gxo_fecha
  FROM comisiones.cgxo_grupoper
     where cms_secuen = pxo.cms_secuen
       and gdo_secuen = (SELECT gdo_secuen
  FROM personal.pfun_funcion fun, personal.puni_unidad uni
    where fun.uni_secuen = uni.uni_secuen
      and fun.fun_secuen = pxo.fun_secuen))::date fecliq,
(case when pxo.cat_secuen_est is null then (select cat_nombre from seguridades.scat_catalogo
 where cat_secuen = (select cat_secuen from comisiones.cgxo_grupoper
   where cms_secuen = pxo.cms_secuen and gdo_secuen = (select gdo_secuen from personal.pfun_funcion fun, personal.puni_unidad uni
   where fun.uni_secuen = uni.uni_secuen
     and fun.fun_secuen = pxo.fun_secuen)))
       else (select cat_nombre from seguridades.scat_catalogo where cat_secuen = pxo.cat_secuen_est) end) estado,
       ((select sum((case when det.dxr_diavia > 0 then round((det.dxr_coef * det.dxr_diavia * pop.pxo_valvia),2) else 0 end) +
       (case when det.dxr_diavia85 > 0 then round((det.dxr_coef * det.dxr_diavia85 * pop.pxo_valvia85),2) else 0 end) +
       (case when det.dxr_diasub > 0 then round((det.dxr_coef * det.dxr_diasub * pop.pxo_valsub)::numeric,2) else 0 end)) totsub
 from comisiones.cpxo_persoper pop, comisiones.cdxr_detruta det
 where pop.cxr_secuen_ant = det.cxr_secuen
   and pop.pxo_secuen = pxo.pxo_secuen
   and dxr_coef > 0)::float) valant, pxo_valorcom::float
  FROM comisiones.cpxo_persoper pxo, comisiones.cord_operacion ord
      Where pxo.cms_secuen = ord.cms_secuen and
        extract(year from cms_fecini) < 2018
        order by 1, 3]]>
	</queryString>
