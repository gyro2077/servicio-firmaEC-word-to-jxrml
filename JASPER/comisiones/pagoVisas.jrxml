	<parameter name="jefegrupo" class="java.lang.Long"/>
	<queryString>
		<![CDATA[select cms_comisi, cms_fecini, cms_fecfin,
       (select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) depend, cms_codigo,
       (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ope.tdo_secuen) tipooper,
       (select personal.f_nombre(1)) jefgru,
        (Select ciu_ciudad || ' - ' || pai_pais
     from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
       where ciu.pai_secuen = pai.pai_secuen
         and ciu_secuen = ope.ciu_secuen) lugar,
        personal.f_nombre(pxo.per_secuen) nombre, per.per_cedula,
        (case when (SELECT sum(fac_total) FROM comisiones.cfac_facturas
          where fac_tipo = 'V' and pxo_secuen = pxo.pxo_secuen) is not null then
          (SELECT sum(fac_total) FROM comisiones.cfac_facturas
          where fac_tipo = 'V' and pxo_secuen = pxo.pxo_secuen) else 0 end) visa,
        (case when (SELECT sum(fac_total) FROM comisiones.cfac_facturas
          where fac_tipo = 'F' and pxo_secuen = pxo.pxo_secuen) is not null then
          (SELECT sum(fac_total) FROM comisiones.cfac_facturas
          where fac_tipo = 'F' and pxo_secuen = pxo.pxo_secuen) else 0 end) formu
   from comisiones.cpxo_persoper pxo, personal.pper_persona per,
        personal.pgmi_gradomil gmi, comisiones.cord_operacion ope,
        personal.pfun_funcion fun, personal.puni_unidad uni
   where pxo.per_secuen = per.per_secuen
     and per.gmi_secuen = gmi.gmi_secuen
     and pxo.cms_secuen = ope.cms_secuen
     and fun.fun_secuen = pxo.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and pxo.cms_secuen = $P{paramIdComision}
     and uni.gdo_secuen = $P{paramIdGrupo}
   order by gmi.gmi_orden, per.per_antigu, nombre]]>
	</queryString>
