	<field name="mes" class="java.lang.String"/>
	<field name="gdo_abreviat" class="java.lang.String">
		<fieldDescription><![CDATA[Abreviatura del grupo de operaciones]]></fieldDescription>
	</field>
	<field name="f_valor_comision_grupo" class="java.lang.Double"/>
	<variable name="mes_sum" class="java.lang.Double" resetType="Group" resetGroup="mes" calculation="Sum">
