	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA["and gxo_fecentfin::date >= '2022-01-01'::date and gxo_fecentfin::date <= '2022-10-04'::date order by 1 desc, 2, 3"]]></defaultValueExpression>
	</parameter>
	<parameter name="titPrincipal" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="marca" class="java.lang.String">
		<defaultValueExpression><![CDATA["poner20caracteres123"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select extract(year from cms_fecini)::int anio,
       lpad((extract(month from cms_fecini))::varchar,2,'0') ||
       (case extract(month from cms_fecini)
          when 1 Then 'ENE' when 2 Then 'FEB' When 3 Then 'MAR' when 4 Then 'ABR'
          when 5 Then 'MAY' When 6 Then 'JUN' when 7 Then 'JUL' when 8 Then 'AGO'
          When 9 Then 'SEP' when 10 Then 'OCT' when 11 Then 'NOV' When 12 Then 'DIC' end) mes,
 gdo.gdo_abreviat, comisiones.f_valor_comision_grupo(gxo.cms_secuen, gxo.gdo_secuen)
 from comisiones.cgxo_grupoper gxo, personal.pgdo_grupoope gdo,
      comisiones.cord_operacion ord, comisiones.ctdo_tipooper tdo
   where gxo.gdo_secuen = gdo.gdo_secuen
     and gxo.cms_secuen = ord.cms_secuen
     and ord.tdo_secuen = tdo.tdo_secuen
     and gxo_fecha is not null
     $P!{sql}]]>
	</queryString>
