	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="sql" class="java.lang.String">
		<defaultValueExpression><![CDATA[" order by pxo_fecdevol"]]></defaultValueExpression>
	</parameter>
	<parameter name="titulo" class="java.lang.String"/>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select pxo_fecdevol, personal.f_nombre(pxo.per_secuen) nombre,
       (select cms_codigo from comisiones.cord_operacion where cms_secuen = pxo.cms_secuen) orden,
       gdo.gdo_abreviat grupo,
       cat_nombre, personal.f_nombre(usu.per_secuen) usuario
 from comisiones.cpxo_persoper pxo, seguridades.scat_catalogo cat,
      seguridades.susu_usuario usu, comisiones.cord_operacion ord,
      personal.pfun_funcion fun,
      personal.puni_unidad uni,
      personal.pgdo_grupoope gdo
  where pxo.cat_secuen_nov = cat.cat_secuen
    and pxo.usu_secuen_comp = usu.usu_secuen
    and pxo.cms_secuen = ord.cms_secuen
    and pxo.fun_secuen = fun.fun_secuen
    and fun.uni_secuen = uni.uni_secuen
    and uni.gdo_secuen = gdo.gdo_secuen
    and pxo.cat_secuen_nov is not null
    and pxo.pxo_feccompr is null
    $P!{sql}]]>
	</queryString>
	<field name="pxo_fecdevol" class="java.sql.Timestamp">
		<fieldDescription><![CDATA[Fecha de devolucion a TTHH.]]></fieldDescription>
	</field>
	<field name="nombre" class="java.lang.String"/>
