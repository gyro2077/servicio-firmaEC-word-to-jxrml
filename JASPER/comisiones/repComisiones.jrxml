		<defaultValueExpression><![CDATA["poner20caracteres123"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT ord.tdo_secuen, tdo_tipooper, cms_fecini, cms_fecfin, cms_codigo, ord.cms_secuen,
 (   case when length(split_part(cms_lugar,',',1)) > 0
     then (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',1)) else '' end ||
     case when length(split_part(cms_lugar,',',2)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',2)) else '' end ||
     case when length(split_part(cms_lugar,',',3)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',3)) else '' end||
     case when length(split_part(cms_lugar,',',4)) > 0
     then ', ' || (select ciu_ciudad from comisiones.cciu_ciudad where ciu_secuen::varchar = split_part(cms_lugar,',',4)) else '' end
) cms_lugar, gdo_abreviat, gxo_fechapro_anticipo, gxo_fecha,
        gxo_fechaoficio, gxo_ordgasto, gxo_fecentfin,
       cat_secuen, (select cat_nombre from seguridades.scat_catalogo where cat_secuen = gxo.cat_secuen) estado,
 comisiones.f_numpersonas_comision_grupo(ord.cms_secuen,gxo.gdo_secuen) totgrupo,
 comisiones.f_valor_comision_grupo(ord.cms_secuen,gxo.gdo_secuen) total,
 (SELECT min(pxo_feccompr)
  FROM comisiones.cpxo_persoper pxo1, personal.pfun_funcion fun1, personal.puni_unidad uni1
    where pxo1.fun_secuen = fun1.fun_secuen
      and fun1.uni_secuen = uni1.uni_secuen
      and pxo1.cms_secuen = ord.cms_secuen
      and uni1.gdo_secuen = gxo.gdo_secuen) comprom,
 (SELECT min(pxo_fecdeven)
  FROM comisiones.cpxo_persoper pxo1, personal.pfun_funcion fun1, personal.puni_unidad uni1
    where pxo1.fun_secuen = fun1.fun_secuen
      and fun1.uni_secuen = uni1.uni_secuen
      and pxo1.cms_secuen = ord.cms_secuen
      and uni1.gdo_secuen = gxo.gdo_secuen) deveng,
 (SELECT min(pxo_fecpago)
  FROM comisiones.cpxo_persoper pxo1, personal.pfun_funcion fun1, personal.puni_unidad uni1
    where pxo1.fun_secuen = fun1.fun_secuen
      and fun1.uni_secuen = uni1.uni_secuen
      and pxo1.cms_secuen = ord.cms_secuen
      and uni1.gdo_secuen = gxo.gdo_secuen) pagado
  FROM comisiones.cgxo_grupoper gxo, comisiones.cord_operacion ord,
  personal.pgdo_grupoope gdo, comisiones.ctdo_tipooper tdo
     where ord.cms_secuen = gxo.cms_secuen
     and gxo.gdo_secuen = gdo.gdo_secuen
     and ord.tdo_secuen = tdo.tdo_secuen
     $P!{sql}]]>
	</queryString>
