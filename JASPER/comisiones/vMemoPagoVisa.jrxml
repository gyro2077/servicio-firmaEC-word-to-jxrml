	<detail>
		<band height="105" splitType="Stretch">
			<textField>
				<reportElement uuid="9a1193fe-6bad-44f1-af50-103a94921a59" x="0" y="0" width="380" height="92"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["Adjunto al presente me permito remitir a usted mi " + $F{graespjefespp} + ", el cálculo de valores generados en la obtención de visas del personal de " + $F{depend} + " que cumplieron la comisión de servicios en " + $P{ciuComision} + "; SEGÚN " + $F{tipooper} + " No. " + $F{cms_codigo} + $P{rectifi} + ", a fin de que se digne autorizar y disponer a quien corresponda se realicen los trámites pertinentes."]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement uuid="d3b683f9-cb84-474a-9aed-9f18a9bd9963" x="422" y="0" width="380" height="102"/>
				<textElement textAlignment="Justified"/>
				<textFieldExpression><![CDATA["Agradeceré a usted señor(a) " + $F{gra} + ", se sirva disponer a quien corresponda, se realice el pago por concepto de devolución de valores generados en la obtención de visas por el valor de " + $F{total} + " (" + $F{totletras} +"), a favor del personal de " + $F{depend} + ", que cumplieron la comisión de servicios en " + $P{ciuComision} + "; SEGUN " + $F{tipooper} + " No. " + $F{cms_codigo} + $P{rectifi} + ", para lo cual adjunto la documentación respectiva."]]></textFieldExpression>
			</textField>
		</band>
	</detail>
