		<defaultValueExpression><![CDATA["c:\\sello.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long">
		<defaultValueExpression><![CDATA[1426]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdGrupo" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="ciuComision" class="java.lang.String"/>
	<parameter name="funcionFirma" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[1]]></defaultValueExpression>
	</parameter>
	<parameter name="rectifi" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="sumilla" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="persona" class="java.lang.Long">
		<defaultValueExpression><![CDATA[1500]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select depend, lugar, round(comisiones.f_valor_visa_grupo($P{paramIdComision},$P{paramIdGrupo})::numeric,2) total,
 comisiones.f_numero_letras(round(comisiones.f_valor_visa_grupo($P{paramIdComision},$P{paramIdGrupo})::numeric,2)) totletras, tipooper, cms_codigo, totreg,
          personal.f_firmas('E',185,0,gxo_fecha::varchar) graesp,
          personal.f_firmas('G',185,0,gxo_fecha::varchar) gra,
          personal.f_firmas('N',185,0,gxo_fecha::varchar) admfin,
          personal.f_firmas('F',185,0,gxo_fecha::varchar) funfin,
          (case when personal.f_firmas('O',208,0,gxo_fecha::varchar)::int >= 40
           then personal.f_firmas('E',208,0,gxo_fecha::varchar) else personal.f_firmas('G',208,0,gxo_fecha::varchar) end) graespjefespp,
          personal.f_firmas('N',208,0,gxo_fecha::varchar) jefespp,
          personal.f_firmas('F',208,0,gxo_fecha::varchar) funspp,
          personal.f_firmas('N',355,0,gxo_fecha::varchar) nomsub,
          personal.f_firmas('E',355,0,gxo_fecha::varchar) graespsub,
          personal.f_firmas('F',355,0,gxo_fecha::varchar) funsub,
          (case when gxo_fecha = '2021-12-30'::date or gxo_fecha > '2022-03-01'::date then personal.f_firmas('R',208,0,gxo_fecha::varchar) else personal.f_firmas('R',355,0,gxo_fecha::varchar) end) resolu,
          (case when $P{persona} > 0 Then (select (case fue_secuen when 6 then '' else gmi_abreviat || '. ' end) || (case fue_secuen when 1 then 'DE ' else '' end) || esp_abrevi || '. ' from personal.pper_persona p, personal.pgmi_gradomil g, personal.pesp_especial e
           where p.gmi_secuen = g.gmi_secuen and p.esp_secuen = e.esp_secuen and
            per_Secuen = $P{persona}) else personal.f_firmas('E',$P{funcionFirma},0,gxo_fecha::varchar) end) graespFirma,
          (case when $P{persona} > 0 Then (select initcap(per_nombre || ' ' || per_apellido)
             from personal.pper_persona p where per_secuen = $P{persona}) else personal.f_firmas('N',$P{funcionFirma},0,gxo_fecha::varchar) end) firma,
          (case when $P{persona} > 0 Then (select fun_funcion from personal.pfun_funcion where fun_secuen = $P{funcionFirma}) else personal.f_firmas('F',$P{funcionFirma},0,gxo_fecha::varchar) end) cargo,
          gxo_fecha, gxo_numofi, gxo_nummem, cms_fecfin
from (select  (select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) depend,
              (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ope.tdo_secuen) tipooper, ope.cms_codigo,
              (Select ciu_ciudad || ' - ' || pai_pais from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
              where ciu.pai_secuen = pai.pai_secuen and ciu_secuen = ope.ciu_secuen) lugar,
              gxo_fecha::date as gxo_fecha, gxo_numofi, gxo_nummem, cms_fecfin, count(*) totreg
   from comisiones.cpxo_persoper pxo, comisiones.cord_operacion ope,
        personal.pfun_funcion fun, personal.puni_unidad uni,
        comisiones.cgxo_grupoper gxo
   where pxo.cms_secuen = ope.cms_secuen
     and fun.fun_secuen = pxo.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and gxo.cms_secuen = pxo.cms_secuen
     and gxo.gdo_secuen = uni.gdo_secuen
     and pxo.pxo_estasi = 1
     and cxr_secuen_pag > 0
     and (pxo_valvia > 0.0 or pxo_valsub > 0.0 or pxo_valali > 0.0)
     and pxo.cms_secuen = $P{paramIdComision}
     and uni.gdo_secuen = $P{paramIdGrupo}
     group by 1,2,3,4,5,6,7,8) a]]>
	</queryString>
