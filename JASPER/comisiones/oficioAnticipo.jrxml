<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="oficioAnticipo" language="groovy" pageWidth="842" pageHeight="595" columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="0" uuid="eb189f50-317f-4939-8950-aed5664255b0">
	<property name="ireport.zoom" value="1.771561000000001"/>
	<property name="ireport.x" value="252"/>
	<property name="ireport.y" value="0"/>
	<parameter name="selloSPP" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\selloSPP.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="sello" class="java.lang.String">
		<defaultValueExpression><![CDATA["c:\\sello.PNG"]]></defaultValueExpression>
	</parameter>
	<parameter name="paramIdComision" class="java.lang.Long"/>
	<parameter name="paramIdGrupo" class="java.lang.Integer"/>
	<parameter name="sumilla" class="java.lang.String">
		<defaultValueExpression><![CDATA[""]]></defaultValueExpression>
	</parameter>
	<parameter name="institucion" class="java.lang.String">
		<defaultValueExpression><![CDATA["CASA MILITAR PRESIDENCIAL"]]></defaultValueExpression>
	</parameter>
	<parameter name="funcionFirma" class="java.lang.Integer">
		<defaultValueExpression><![CDATA[187]]></defaultValueExpression>
	</parameter>
	<parameter name="P_CEDULA_USUARIO" class="java.lang.String"/>
	<queryString>
		<![CDATA[select depend, lugar, round(total::numeric,2) total, tipooper, cms_codigo,
    (select count(*)
        from comisiones.cpxo_persoper pxo, personal.pfun_funcion fun,
             personal.puni_unidad uni
         where pxo.fun_secuen = fun.fun_secuen
           and fun.uni_secuen = uni.uni_secuen
           and pxo_estasi = 1
           and cms_secuen = $P{paramIdComision}
           and uni.gdo_secuen = $P{paramIdGrupo})totreg,
           personal.f_firmas('E',185,0,gxo_fechaoficio::varchar) graesp,
           personal.f_firmas('N',185,0,gxo_fechaoficio::varchar) admfin,
           personal.f_firmas('F',185,0,gxo_fechaoficio::varchar) funfin,
           personal.f_firmas('G',185,0,gxo_fechaoficio::varchar) gra,
           personal.f_firmas('N',$P{funcionFirma},0,gxo_fechaoficio::varchar) dirth,
           personal.f_firmas('E',$P{funcionFirma},0,gxo_fechaoficio::varchar) graespjefeth,
           personal.f_firmas('F',$P{funcionFirma},0,gxo_fechaoficio::varchar) funth,
	       COALESCE((SELECT per2.per_cedula FROM personal.pfxp_funcpers fxp2 JOIN personal.pper_persona per2 ON fxp2.per_secuen = per2.per_secuen WHERE fxp2.fun_secuen = $P{funcionFirma} AND gxo_fechaoficio::date BETWEEN fxp2.fxp_fecini AND COALESCE(fxp2.fxp_fecfin, gxo_fechaoficio::date + 20) LIMIT 1), 'NO REGISTRADA') cedula_autoridad,
           gxo_fechapro_anticipo, gxo_fechaoficio, gxo_numfin, gxo_nummem
from (select  (select gdo_grupoope from personal.pgdo_grupoope where gdo_secuen = uni.gdo_secuen) depend,
              (select tdo_tipooper from comisiones.ctdo_tipooper where tdo_secuen = ope.tdo_secuen) tipooper, ope.cms_codigo,
              (Select ciu_ciudad || ' - ' || pai_pais from comisiones.cciu_ciudad ciu, comisiones.cpai_pais pai
              where ciu.pai_secuen = pai.pai_secuen and ciu_secuen = ope.ciu_secuen) lugar,
              gxo_fechapro_anticipo, gxo_fechaoficio, gxo_numfin, gxo_nummem,
       sum(case when (det.dxr_diavia > 0) then round((det.dxr_coef * det.dxr_diavia * pxo.pxo_valvia),2) else 0 end +
       case when (det.dxr_diavia85 > 0) then round((det.dxr_coef * det.dxr_diavia85 * pxo.pxo_valvia85),2) else 0 end +
       case when (det.dxr_diasub > 0) then round((det.dxr_coef * det.dxr_diasub * pxo.pxo_valsub)::numeric,2) else 0 end +
       case when (det.dxr_diaali > 0) then round((det.dxr_coef * det.dxr_diaali * pxo.pxo_valali),2) else 0 end) as total
   from comisiones.cpxo_persoper pxo, comisiones.cord_operacion ope,
        personal.pfun_funcion fun, personal.puni_unidad uni,
        comisiones.ccxr_cabruta cab, comisiones.cdxr_detruta det,
        comisiones.cgxo_grupoper gxo
   where pxo.cms_secuen = ope.cms_secuen
     and fun.fun_secuen = pxo.fun_secuen
     and fun.uni_secuen = uni.uni_secuen
     and pxo.cxr_secuen_ant = cab.cxr_secuen
     and cab.cxr_Secuen = det.cxr_secuen
     and gxo.cms_secuen = pxo.cms_secuen
     and gxo.gdo_secuen = uni.gdo_secuen
     and det.dxr_coef > 0
     and pxo.cms_secuen = $P{paramIdComision}
     and uni.gdo_secuen = $P{paramIdGrupo}
     group by 1,2,3,4,5,6,7,8) a]]>
	</queryString>
